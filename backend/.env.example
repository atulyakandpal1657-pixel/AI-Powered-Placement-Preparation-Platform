# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/placeprep

# Auth
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=7d

# Cloudinary (resume uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI resume analysis
GEMINI_API_KEY=

# Demo one-click login (backend serves credentials; never hardcode in frontend)
ENABLE_DEMO_ACCOUNTS=true
DEMO_USER_EMAIL=demo.user@placeprep.ai
DEMO_USER_PASSWORD=Demo@123
DEMO_ADMIN_EMAIL=demo.admin@placeprep.ai
DEMO_ADMIN_PASSWORD=Admin@123
